# Base de datos y Storage de Supabase
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@HOST:6543/postgres?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Acceso interno del piloto
# Generar con: node -e "require('argon2').hash('TU_CLAVE').then(console.log)"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
AUTH_RATE_LIMIT_SALT=

# URLs y notificaciones
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Opcional: fija una release de yt-dlp (por defecto se instala la última disponible)
YT_DLP_VERSION=
REQUIRE_AUTH=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=VSL Studio <onboarding@resend.dev>
INTAKE_NOTIFICATION_EMAIL=

# OpenRouter es el proveedor prioritario; Anthropic queda como alternativa.
OPENROUTER_API_KEYS=
OPENROUTER_TRANSCRIPTION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# selfhosted | auto | openrouter | groq. En "auto" se prioriza el worker Whisper propio.
TRANSCRIPTION_PROVIDER=auto
# Worker Whisper self-hosted (faster-whisper). Ver worker/whisper/README.md.
# URL completa del endpoint de transcripción, ej.: https://tu-tunel.example/transcribe
WHISPER_ENDPOINT=
WHISPER_API_KEY=
WHISPER_MODEL=faster-whisper/base
# Respaldo opcional de audio cuando OpenRouter no tiene el saldo mínimo de activación.
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
ANTHROPIC_API_KEY=
